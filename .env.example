PAGARME_API_KEY=ak_live_xxxxxxxxxxxxxxxx
PAGARME_WEBHOOK_SECRET=seu_webhook_secret_pagarme

# ── FORNECEDORES ───────────────────────────────────────────
ALIEXPRESS_APP_KEY=seu_app_key
ALIEXPRESS_APP_SECRET=seu_app_secret
