FOCUSNFE_AMBIENTE=producao   # ou homologacao
CNPJ_EMITENTE=00000000000000

# ── NOTIFICAÇÕES + WORKERS ─────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=seu_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
DEEPL_API_KEY=sua_chave_deepl              # opcional — tradução automática
WORKER_SECRET_KEY=string_aleatoria_min_64_chars_NUNCA_expor
